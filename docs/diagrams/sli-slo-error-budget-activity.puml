@startuml
title Decision Intelligence API - SLI/SLO/Error Budget Decision Flow

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 16
skinparam titleFontSize 22

skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  FontColor #0F172A
  StartColor #22C55E
  EndColor #EF4444
  DiamondBackgroundColor #E0F2FE
  DiamondBorderColor #0284C7
}

skinparam note {
  BackgroundColor #FEF3C7
  BorderColor #F59E0B
}

start

:Collect observability signals;

note right
Sources:
- Prometheus / Blackbox
- Kubernetes API
- OpenSearch
- Platform collectors
end note

:Normalize signal payload;

:Evaluate incident rules;

note right
Multi-rule / multi-scenario engine
matches workload or platform scenarios
end note

if (Incident rule matched?) then (yes)

  :Build DecisionResponse;

  note right
  Decision includes:
  - impact
  - evidence
  - likely root cause
  - safe action
  - metadata
  end note

  :Read affected SLO from decision;

  note right
  Example:
  slo_affected = frontend-availability
  end note

  :Map affected SLO to registered SLO policy;

  note right
  SLO Registry:
  frontend-availability
  -> frontend-availability-30d
  end note

  if (SLO mapping found?) then (yes)

    :Read current SLI value from signals;

    note right
    Example:
    frontend_availability_5m = 0.6
    end note

    if (Valid ratio-based SLI value?) then (yes)

      :Calculate error budget evaluation;

      note right
      Formula:
      allowed failure = 1 - SLO target
      current failure = 1 - current SLI
      budget consumed = current failure / allowed failure
      budget remaining = max(0, 1 - consumed)
      end note

      if (Budget consumed >= 100%?) then (yes)
        :Set SLO status = exhausted;
        :Classify reliability impact as high;
      else (no)

        if (Budget consumed >= critical threshold?) then (yes)
          :Set SLO status = burning_fast;
          :Classify reliability impact as elevated;
        else (no)

          if (Budget consumed >= warning threshold?) then (yes)
            :Set SLO status = warning;
            :Classify reliability impact as medium;
          else (no)
            :Set SLO status = healthy;
            :Classify reliability impact as low;
          endif

        endif

      endif

      :Attach slo_evaluation to DecisionResponse;

      note right
      slo_evaluation includes:
      - SLO ID
      - SLI name
      - target
      - current value
      - allowed failure
      - budget consumed
      - budget remaining
      - status
      - summary
      end note

      :Expose enriched API response;

    else (no)

      :Return decision without SLO evaluation;

      note right
      Reason:
      missing or invalid SLI value
      end note

    endif

  else (no)

    :Return decision without SLO evaluation;

    note right
    Reason:
    no SLO mapping for scenario
    end note

  endif

else (no)

  :Return no matching incident decision;

endif

stop

@enduml